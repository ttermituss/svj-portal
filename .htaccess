Options -Indexes

# ===== Gzip komprese =====
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript text/javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    # Nekomprimovat už komprimované formáty
    SetEnvIfNoCase Request_URI \.(gz|zip|jpg|jpeg|png|gif|webp)$ no-gzip
</IfModule>

# ===== Cache headers pro statické soubory =====
<IfModule mod_headers.c>
    # CSS, JS, fonty — 30 dní (immutable = prohlížeč nerevaliduje do expirace)
    <FilesMatch "\.(css|js|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    # Service Worker — vždy revalidovat (přebije *.js pravidlo výše)
    <FilesMatch "^sw\.js$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
    # Obrázky — 7 dní
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
    # HTML (SPA shell) — vždy revalidovat
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
    # API odpovědi — no-store (obsahují citlivá data)
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# ===== Security Headers =====
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
    Header always set X-XSS-Protection "0"
    # HSTS — odkomentovat po potvrzení HTTPS v produkci:
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # CSP — SPA s inline skripty, povoluje self + Google API + OpenStreetMap
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://api.qrserver.com https://*.tile.openstreetmap.org; font-src 'self'; connect-src 'self' https://api.open-meteo.com https://overpass-api.de https://ags.cuzk.cz https://ares.gov.cz https://api-kn.cuzk.gov.cz https://accounts.google.com https://www.googleapis.com https://oauth2.googleapis.com; frame-src 'self' https://www.openstreetmap.org; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"
</IfModule>

# Rewrite engine
RewriteEngine On

# Blokovat přímý přístup na config.php a db.php
RewriteRule ^api/config\.php$ - [F,L]
RewriteRule ^api/db\.php$ - [F,L]
RewriteRule ^api/helpers\.php$ - [F,L]
RewriteRule ^api/middleware\.php$ - [F,L]
RewriteRule ^api/session\.php$ - [F,L]

# API požadavky jdou přímo na PHP soubory
RewriteRule ^api/(.+)$ api/$1 [L]

# Vše ostatní na index.html (SPA router)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api/
RewriteRule ^ index.html [L]
