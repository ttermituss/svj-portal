# Blokovat interní soubory
<FilesMatch "^(config|db|helpers|session|middleware|proxy|ratelimit|settings_crypto|svj_helper|fond_notif_helper|storage_helper|xlsx_helper|pdf_helper|zfo_parser|google_helper|bootstrap)\.php$">
    Require all denied
</FilesMatch>

# Blokovat migrations
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^migrations/ - [F,L]
</IfModule>

# Security headers pro API (doplňují root .htaccess)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    # X-Frame-Options nastavuje PHP endpoint dle kontextu (inline náhled vs. stažení)
</IfModule>
